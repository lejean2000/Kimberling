Cell["Curves duplicate checks", "Text",
 Background->GrayLevel[
  0.85],ExpressionUUID->"8c0484be-a6c4-4799-b62c-f228787c907e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"arr", "=", 
   RowBox[{"Association", "[", "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[982]:=",ExpressionUUID->"09883be0-e6cc-4f96-a58d-ec44720fa3bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"check", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"st", "[", "name", "]"}], "/.", "rule69"}], "/.", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", "y", ",", "z"}], "}"}], "->", 
           RowBox[{"{", 
            RowBox[{"3", ",", "7", ",", "11"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AssociateTo", "[", 
        RowBox[{"arr", ",", 
         RowBox[{"name", "->", "check"}]}], "]"}], ";"}], 
      "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"name", ",", 
        RowBox[{"Keys", "[", "st", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"st", ",", 
      RowBox[{"{", 
       RowBox[{
       "fltInCircles", ",", "fltCentralCircles", ",", "fltDuals", ",", " ", 
        "fltOrthoptic"}], "}"}]}], "}"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellLabel->
  "In[983]:=",ExpressionUUID->"472a42a6-af0f-4186-8e83-2bd675fe3580"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{"Values", "[", "arr", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"uniqueValues", "=", 
   RowBox[{"Union", "[", "values", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"duplicateValues", "=", 
   RowBox[{"Part", "[", 
    RowBox[{
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Tally", "[", "values", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ">", "1"}], "&"}]}], "]"}], ",", 
     "All", ",", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"duplicatesInAssociation", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"arr", ",", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{"duplicateValues", ",", 
        RowBox[{"#", "/.", " ", 
         RowBox[{
          RowBox[{"Association", "[", "__", "]"}], "->", 
          RowBox[{
           RowBox[{"Key", "[", "__", "]"}], "->", 
           RowBox[{"Value", "[", "__", "]"}]}]}]}]}], "]"}], "&"}]}], "]"}]}],
   ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"duplicatesInAssociation", "//", "Sort"}], "]"}]}], "Input",
 CellLabel->
  "In[984]:=",ExpressionUUID->"e50200b7-7c26-47d8-ac7d-d19a63a15ca7"],

