                  RowBox[{
                   SuperscriptBox["v", "2"], "+", 
                   RowBox[{"v", " ", "w"}], "+", 
                   SuperscriptBox["w", "2"]}], ")"}]}]}], ")"}], ",", "idx"}],
              "]"}], "]"}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
