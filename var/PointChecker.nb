Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", " ", "Step"}]}], " ", "2"}], ":", " ", 
    RowBox[{
     RowBox[{"Data", " ", "Loading", " ", 
      RowBox[{"Script", "  ", "--"}]}], "-"}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
    "inputFile", " ", "=", " ", "\"\<../db/precomputed_triangles.mx\>\""}], 
    ";"}], "\n", "\n", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"!", " ", 
      RowBox[{"FileExistsQ", "[", "inputFile", "]"}]}], ",", "\n", "  ", 
     RowBox[{
     "Print", "[", 
      "\"\<Error: Pre-computed file not found. Please run the corrected \
pre-computation script first.\>\"", "]"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Loading pre-computed data from \>\"", " ", "<>", " ", "inputFile",
         " ", "<>", " ", "\"\<...\>\""}], "]"}], ";", "\n", "  ", "\n", "  ", 
      RowBox[{"loadedData", " ", "=", " ", 
       RowBox[{"Import", "[", "inputFile", "]"}]}], ";", "\n", "  ", "\n", 
      "  ", 
      RowBox[{"precomputedKimberling", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<Kimberling\>\"", "]"}]}], ";", "\n", 
      "  ", 
      RowBox[{"precomputedCPTR", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<CPTR\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"precomputedENCTR", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<ENCTR\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"allPrecomputedTrJoined", "=", 
       RowBox[{"Join", "[", 
