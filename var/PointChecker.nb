 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"name", "=", 
     RowBox[{"\"\<X\>\"", "<>", 
      RowBox[{"ToString", "[", "idx", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
