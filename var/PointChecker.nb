              RowBox[{
               RowBox[{"Take", "[", 
                RowBox[{"KimberlingTrianglesBary", ",", 
                 RowBox[{"{", 
                  RowBox[{"223", ",", 
                   RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", 
               "\[IndentingNewLine]", 
