              RowBox[{"[", "1", "]"}], "]"}], ",", "10", ",", "1", ",", 
             "50"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"trgCheckPerspectivity", "[", "trgexpr", "]"}], "<", 
            "3"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Print", "[", "trgname", "]"}], ";", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"out", ",", "trgname"}], "]"}], ";"}]}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";"}],
       "\[IndentingNewLine]", ",", 
