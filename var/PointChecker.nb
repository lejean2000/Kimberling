Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"buildENCTR", "[", 
    RowBox[{"trg_", ",", "trgname_", ",", 
     RowBox[{"forced_", ":", 
      RowBox[{"{", "}"}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"key", ",", "trgexpr", ",", "checkexists"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"newtr", "=", 
       RowBox[{"<|", "|>"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"Global", " ", "var"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Monitor", "[", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"Not", "[", 
              RowBox[{"ValueQ", "[", "trg", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", "\"\<NO TRG\>\"", "]"}], ";", 
              RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"key", "=", 
            RowBox[{"StringReplace", "[", 
             RowBox[{"trgname", ",", 
              RowBox[{"\"\<XX\>\"", "->", 
               RowBox[{"ToString", "[", "nx", "]"}]}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"KeyExistsQ", "[", 
              RowBox[{"CPTR", ",", "key"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"\"\<KEY EXISTS:\>\"", "<>", "key"}], "]"}], ";", 
              RowBox[{"(*", 
               RowBox[{"newtr", "=", 
                RowBox[{"<|", 
                 RowBox[{"//", ";"}], " "}]}], "*)"}], 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"trgexpr", "=", 
            RowBox[{"TimeConstrained", "[", 
             RowBox[{
              RowBox[{"simplifyRationalBarycentrics", "/@", 
               RowBox[{"partialSReplace", "/@", 
                RowBox[{"replacerExprNoeval", "[", 
                 RowBox[{"trg", ",", "nx"}], "]"}]}]}], ",", "5", ",", 
              RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"trgexpr", "==", 
               RowBox[{"-", "1"}]}], "||", 
              RowBox[{
               RowBox[{
                RowBox[{"trgexpr", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], "===", "Indeterminate"}]}], 
             ",", 
             RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"Not", "[", 
              RowBox[{"MemberQ", "[", 
               RowBox[{"forced", ",", "nx"}], "]"}], "]"}], ",", 
             RowBox[{"(*", 
              RowBox[{
              "skip", " ", "checks", " ", "for", " ", "forced", " ", 
               "items"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Not", "[", 
                  RowBox[{"heuristicsCheck", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"trgexpr", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", "8", ",", "2", ",", 
                    "60"}], "]"}], "]"}], "||", 
                 RowBox[{"Not", "[", 
                  RowBox[{"heuristicsCheck", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"trgexpr", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", "8", ",", "2", ",", 
                    "60"}], "]"}], "]"}]}], ",", " ", 
                RowBox[{"Continue", "[", "]"}]}], "]"}], ";"}]}], 
            "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
           "\[IndentingNewLine]", 
           RowBox[{"checkexists", " ", "=", " ", 
            RowBox[{"checkTriangleExists", "[", "trgexpr", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"checkexists", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"key", "<>", "\"\< = \>\"", "<>", 
                RowBox[{"checkexists", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ";", 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"bCollinearityMatrix", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"evaluate", "[", "trgexpr", "]"}], "/.", "rule69"}],
                  ")"}]}], "]"}], "<", 
              SuperscriptBox["10", 
               RowBox[{"-", "20"}]]}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"key", "<>", "\"\< degenerate\>\""}], "]"}], ";", 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"AssociateTo", "[", 
            RowBox[{"newtr", ",", 
             RowBox[{"key", "->", "trgexpr"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Print", "[", "key", "]"}], ";"}], "\[IndentingNewLine]", 
          ",", 
          RowBox[{"{", 
           RowBox[{"nx", ",", " ", "1", ",", "101"}], "}"}]}], 
         "\[IndentingNewLine]", "]"}], ",", "nx"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"AssociateTo", "[", 
       RowBox[{"CPTR", ",", "newtr"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"DumpSave", "[", 
       RowBox[{"\"\<CPTR1.mx\>\"", ",", "CPTR"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9721143510051036`*^9, 3.972114366182208*^9}, {
   3.9721154467782865`*^9, 3.9721154481298323`*^9}, {3.972118383684814*^9, 
   3.972118384178033*^9}, {3.9721283549217744`*^9, 3.9721283549217744`*^9}, 
   3.9721291036377287`*^9, 3.972129138940748*^9, {3.978691698442703*^9, 
   3.9786917357996335`*^9}},
 Background->RGBColor[1, 0.925, 0.925],
 CellLabel->"In[49]:=",ExpressionUUID->"846897ec-de8c-4b08-bcf7-3d100b252a37"],

