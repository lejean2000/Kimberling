Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", "=", 
   RowBox[{"sym3", "[", 
    RowBox[{"p", " ", "u", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"r", " ", "v"}], "+", 
       RowBox[{"q", " ", "w"}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"p", " ", 
        SuperscriptBox["r", "2"], " ", "u", " ", 
        SuperscriptBox["v", "2"]}], "+", 
       RowBox[{"p", " ", 
        SuperscriptBox["q", "2"], " ", "u", " ", 
        SuperscriptBox["w", "2"]}], "+", 
       RowBox[{"q", " ", "v", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox["u", "2"]}], "-", 
          RowBox[{"4", " ", "p", " ", "r", " ", "u", " ", "w"}], "+", 
          RowBox[{
           SuperscriptBox["p", "2"], " ", 
           SuperscriptBox["w", "2"]}]}], ")"}]}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["q", "2"], " ", "r", " ", 
        SuperscriptBox["u", "2"], " ", "w"}], "+", 
       RowBox[{
        SuperscriptBox["p", "2"], " ", "r", " ", 
        SuperscriptBox["v", "2"], " ", "w"}], "+", 
       RowBox[{"p", " ", "u", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox["v", "2"]}], "-", 
          RowBox[{"4", " ", "q", " ", "r", " ", "v", " ", "w"}], "+", 
          RowBox[{
           SuperscriptBox["q", "2"], " ", 
           SuperscriptBox["w", "2"]}]}], ")"}]}]}], ")"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"in", "==", "2"}], ",", 
      RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{"in", ",", "im"}], "}"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"ptcoord", "=", 
     RowBox[{
      RowBox[{"replacer", "[", 
       RowBox[{"expr", ",", "in", ",", "im"}], "]"}], "//", 
      "simplifyRationalBarycentrics"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"tot", "=", 
     RowBox[{
      RowBox[{"quickChecker", "[", 
       RowBox[{"ptcoord", ",", "0", ",", "True"}], "]"}], "//", "Total"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"crvsnum", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"checkCurves", "[", "ptcoord", "]"}], "//", "Quiet"}], "//", 
      "Length"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"tot", "+", 
        RowBox[{"10", "*", "crvsnum"}]}], ">", "10"}], ",", 
      RowBox[{
       RowBox[{"AppendTo", "[", 
        RowBox[{"out", ",", 
         RowBox[{"{", 
          RowBox[{"in", ",", "im"}], "}"}]}], "]"}], ";", 
       RowBox[{"Print", "[", "out", "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", ",", 
   RowBox[{"{", 
    RowBox[{"in", ",", "1", ",", "12"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"im", ",", 
     RowBox[{"Max", "[", 
      RowBox[{"3", ",", 
       RowBox[{"in", "+", "1"}]}], "]"}], ",", "12"}], "}"}]}], 
