Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"{", "}"}]}], ";", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"trgexpr", "=", 
        RowBox[{"ENCTR", "[", "trgname", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"heuristicsCheck", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"trgexpr", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "10", ",", "1", ",", 
             "50"}], "]"}], "]"}], "||", 
          RowBox[{"Not", "[", 
           RowBox[{"heuristicsCheck", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"trgexpr", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", "10", ",", "1", ",", 
             "50"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"trgCheckPerspectivity", "[", "trgexpr", "]"}], "<", 
            "3"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Print", "[", "trgname", "]"}], ";", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"out", ",", "trgname"}], "]"}], ";"}]}], 
          "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";"}],
       "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"trgname", ",", 
        RowBox[{"Keys", "[", 
         RowBox[{"KeySelect", "[", 
          RowBox[{"ENCTR", ",", 
           RowBox[{
            RowBox[{"StringContainsQ", "[", 
             RowBox[{"#", ",", "\"\<CTR5\>\""}], "]"}], "&"}]}], "]"}], 
         "]"}]}], "}"}]}], "]"}], ",", "trgname"}], "]"}], ";"}]], "Input",
 CellLabel->"In[79]:=",ExpressionUUID->"ddf43144-1f72-4696-ac6a-f85fca0b03df"],

