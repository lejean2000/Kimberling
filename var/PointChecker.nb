      RowBox[{"in", "==", "2"}], ",", 
      RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", "in", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"ptcoord", "=", 
     RowBox[{"simplifyRationalBarycentrics", "[", 
