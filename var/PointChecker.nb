Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"checkPointinETC2", "[", "ptnum_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"set", ",", "out", ",", "cmplx"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"AllTrue", "[", 
         RowBox[{"ptnum", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Im", "[", "#1", "]"}], "\[Equal]", "0"}], "&"}]}], "]"}],
         ",", 
        RowBox[{"set", "=", 
         RowBox[{"Keys", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"ETCBaryNorm", ",", 
            RowBox[{
             RowBox[{"#1", "\[Equal]", "ptnum"}], "&"}]}], "]"}], "]"}]}], 
        ",", 
        RowBox[{
         RowBox[{"cmplx", "=", 
          RowBox[{"Keys", "[", 
           RowBox[{"Select", "[", 
            RowBox[{"ETCBaryNorm", ",", 
             RowBox[{
              RowBox[{"AnyTrue", "[", 
               RowBox[{"#1", ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Im", "[", "#1", "]"}], "\[NotEqual]", "0"}], 
                 "&"}]}], "]"}], "&"}]}], "]"}], "]"}]}], ";", 
         RowBox[{"set", "=", 
          RowBox[{"Select", "[", 
           RowBox[{"cmplx", ",", 
            RowBox[{
             RowBox[{"coincide", "[", 
              RowBox[{
               RowBox[{"ETCBaryNorm", "[", "#1", "]"}], ",", "ptnum"}], "]"}],
              "&"}]}], "]"}]}], ";"}]}], "]"}], ";", 
      RowBox[{"out", "=", 
       RowBox[{"{", "}"}]}], ";", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"Length", "[", "set", "]"}], ">", "0"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 Background->RGBColor[1, 0.9, 1],
 CellLabel->
  "In[434]:=",ExpressionUUID->"d4737001-92e1-425d-a9f1-4bace66eeb30"],

