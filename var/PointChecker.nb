                   RowBox[{"#", ",", "\"\<isodyn\>\""}], "]"}], "]"}]}], 
                "\[IndentingNewLine]", "&"}]}], "]"}], "\[IndentingNewLine]", 
             "]"}]}], "}"}]}], "\[IndentingNewLine]", "]"}], ",", "trname"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AssociateTo", "[", 
