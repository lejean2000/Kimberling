Cell[BoxData[{
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{"Values", "[", "arr", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"uniqueValues", "=", 
   RowBox[{"Union", "[", "values", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"duplicateValues", "=", 
   RowBox[{"Part", "[", 
    RowBox[{
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Tally", "[", "values", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ">", "1"}], "&"}]}], "]"}], ",", 
     "All", ",", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"duplicatesInAssociation", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"arr", ",", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{"duplicateValues", ",", 
        RowBox[{"#", "/.", " ", 
         RowBox[{
          RowBox[{"Association", "[", "__", "]"}], "->", 
          RowBox[{
           RowBox[{"Key", "[", "__", "]"}], "->", 
           RowBox[{"Value", "[", "__", "]"}]}]}]}]}], "]"}], "&"}]}], "]"}]}],
   ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"duplicatesInAssociation", "//", "Sort"}], "]"}]}], "Input",
 CellLabel->
  "In[984]:=",ExpressionUUID->"e50200b7-7c26-47d8-ac7d-d19a63a15ca7"],

