Cell["", "Text",ExpressionUUID->"bbd50a75-f4d7-44de-9713-f9aa7aa7fee6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", " ", "Step"}]}], " ", "2"}], ":", " ", 
    RowBox[{
     RowBox[{"Data", " ", "Loading", " ", 
      RowBox[{"Script", "  ", "--"}]}], "-"}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
    "inputFile", " ", "=", " ", "\"\<../db/precomputed_triangles.mx\>\""}], 
    ";"}], "\n", "\n", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"!", " ", 
      RowBox[{"FileExistsQ", "[", "inputFile", "]"}]}], ",", "\n", "  ", 
     RowBox[{
     "Print", "[", 
      "\"\<Error: Pre-computed file not found. Please run the corrected \
pre-computation script first.\>\"", "]"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Loading pre-computed data from \>\"", " ", "<>", " ", "inputFile",
         " ", "<>", " ", "\"\<...\>\""}], "]"}], ";", "\n", "  ", "\n", "  ", 
      
      RowBox[{"loadedData", " ", "=", " ", 
       RowBox[{"Import", "[", "inputFile", "]"}]}], ";", "\n", "  ", "\n", 
      "  ", 
      RowBox[{"precomputedKimberling", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<Kimberling\>\"", "]"}]}], ";", "\n", 
      "  ", 
      RowBox[{"precomputedCPTR", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<CPTR\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"precomputedENCTR", " ", "=", " ", 
       RowBox[{"loadedData", "[", "\"\<ENCTR\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"allPrecomputedTrJoined", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
        "precomputedKimberling", ",", "precomputedCPTR", ",", 
         "precomputedENCTR"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"Print", "[", "\"\<Data loaded successfully.\>\"", "]"}], 
      ";"}]}], "\n", "]"}], "\[IndentingNewLine]", 
   RowBox[{"duplicates", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"GroupBy", "[", 
       RowBox[{
        RowBox[{"Normal", "[", "allPrecomputedTrJoined", "]"}], ",", 
        RowBox[{"Last", "->", "First"}]}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "#", "]"}], ">", "1"}], "&"}]}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.972128492066242*^9, 3.97212849208052*^9}, {
