Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"buildCPTRFromKim", "[", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"key", ",", "trgexpr", ",", "checkexists"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"newtr", "=", 
       RowBox[{"<|", "|>"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"Global", " ", "var"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"Not", "[", 
              RowBox[{"ValueQ", "[", "trg", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", "\"\<NO TRG\>\"", "]"}], ";", 
              RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"key", "=", 
            RowBox[{"\"\<g(\>\"", "<>", "trname", "<>", "\"\<)\>\""}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"KeyExistsQ", "[", 
              RowBox[{"CPTR", ",", "key"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"\"\<KEY EXISTS:\>\"", "<>", "key"}], "]"}], ";", 
              RowBox[{"(*", 
               RowBox[{"newtr", "=", 
                RowBox[{"<|", 
                 RowBox[{"//", ";"}], " "}]}], "*)"}], 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"trgexpr", "=", 
            RowBox[{"TimeConstrained", "[", 
             RowBox[{
              RowBox[{"simplifyRationalBarycentrics", "/@", 
               RowBox[{"partialSReplace", "/@", 
                RowBox[{"funcg", "/@", 
                 RowBox[{"triangle", "[", "trname", "]"}]}]}]}], ",", "10", 
              ",", 
              RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"trgexpr", "==", 
               RowBox[{"-", "1"}]}], "||", 
              RowBox[{
               RowBox[{
                RowBox[{"trgexpr", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], "===", "Indeterminate"}]}], 
             ",", 
             RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"checkexists", " ", "=", " ", 
            RowBox[{"checkTriangleExists", "[", "trgexpr", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"checkexists", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"key", "<>", "\"\< = \>\"", "<>", 
                RowBox[{"checkexists", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ";", 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Not", "[", 
               RowBox[{"heuristicsCheck", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"trgexpr", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", "12", ",", "2.5", ",", 
                 "80"}], "]"}], "]"}], "||", 
              RowBox[{"Not", "[", 
               RowBox[{"heuristicsCheck", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"trgexpr", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", "12", ",", "2.5", ",", 
                 "80"}], "]"}], "]"}]}], ",", " ", 
             RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"check", " ", "=", " ", 
            RowBox[{"Abs", "[", 
             RowBox[{"bCollinearityMatrix", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"evaluate", "[", "trgexpr", "]"}], "/.", "rule69"}], 
               ")"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"Not", "[", 
              RowBox[{"Internal`RealValuedNumericQ", "[", "check", "]"}], 
              "]"}], ",", 
             RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"check", "<", 
              SuperscriptBox["10", 
               RowBox[{"-", "20"}]]}], ",", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"key", "<>", "\"\< degenerate\>\""}], "]"}], ";", 
              RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"AssociateTo", "[", 
            RowBox[{"newtr", ",", 
