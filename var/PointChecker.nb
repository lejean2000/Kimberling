Cell["LOOPING TRIANGLES", "Text",
 CellChangeTimes->{{3.985414247581957*^9, 
  3.985414250486616*^9}},ExpressionUUID->"0f22ffdc-fae7-48da-a942-\
0892858e3d1c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"trf", "=", 
      RowBox[{"symtr", "[", 
       RowBox[{"KimberlingTrianglesBary", "[", "trn", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"check", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"evaluate", "[", 
         RowBox[{"bIsParallel", "[", 
          RowBox[{
           RowBox[{"Cross", "[", 
            RowBox[{
             RowBox[{"trf", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"trf", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}], "]"}], ",", 
           RowBox[{"Cross", "[", 
            RowBox[{"xA", ",", 
             RowBox[{"bMidpoint", "[", 
              RowBox[{"xB", ",", "xC"}], "]"}]}], "]"}]}], "]"}], "]"}], "/.",
         "rule69"}], "//", "Simplify"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"check", "==", "0"}], ",", 
       RowBox[{"Print", "[", "trn", "]"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"trn", ",", 
      RowBox[{"Keys", "[", "KimberlingTrianglesBary", "]"}]}], "}"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.985414254123666*^9, 
  3.985414256370458*^9}},ExpressionUUID->"b76f132c-6c62-44ef-a810-\
b19770d07cce"],

