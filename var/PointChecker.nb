  RowBox[{"checkTriangleExists2", "[", 
   RowBox[{"tr_", ",", "trset_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"chk", ",", "ex"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ex", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
