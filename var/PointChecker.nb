 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"{", "}"}]}], ";", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"trgexpr", "=", 
        RowBox[{"ENCTR", "[", "trgname", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"heuristicsCheck", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"trgexpr", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "10", ",", "1", ",", 
             "50"}], "]"}], "]"}], "||", 
