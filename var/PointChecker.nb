  FractionBox[
   RowBox[{"Det", "[", "tr", "]"}], 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"tr", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "]"}], 
