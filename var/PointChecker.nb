Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"check", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"st", "[", "name", "]"}], "/.", "rule69"}], "/.", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", "y", ",", "z"}], "}"}], "->", 
           RowBox[{"{", 
            RowBox[{"3", ",", "7", ",", "11"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AssociateTo", "[", 
        RowBox[{"arr", ",", 
         RowBox[{"name", "->", "check"}]}], "]"}], ";"}], 
      "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"name", ",", 
        RowBox[{"Keys", "[", "st", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"st", ",", 
      RowBox[{"{", 
       RowBox[{
       "fltInCircles", ",", "fltCentralCircles", ",", "fltDuals", ",", " ", 
        "fltOrthoptic"}], "}"}]}], "}"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellLabel->
  "In[983]:=",ExpressionUUID->"472a42a6-af0f-4186-8e83-2bd675fe3580"],

